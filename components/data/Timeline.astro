---
/**
 * Timeline - Chronological list of events or activity steps.
 *
 * @component Timeline
 * @category data
 * @slot default - TimelineItem children
 */

export interface TimelineItem {
  /** Event title */
  title: string;
  /** Event description */
  description?: string;
  /** Date or time string */
  date?: string;
  /** Icon path (SVG d attribute) */
  icon?: string;
  /** Dot color variant */
  variant?: "default" | "primary" | "success" | "warning" | "danger";
}

export interface Props {
  /** Timeline items (alternatively use slot for custom items) */
  items?: TimelineItem[];
  /** Layout direction */
  orientation?: "vertical" | "horizontal";
  /** Additional CSS classes */
  class?: string;
}

const {
  items = [],
  orientation = "vertical",
  class: className = "",
} = Astro.props;

const dotColorMap: Record<string, string> = {
  default: "bg-gray-400 ring-gray-200",
  primary: "bg-blue-500 ring-blue-100",
  success: "bg-green-500 ring-green-100",
  warning: "bg-yellow-400 ring-yellow-100",
  danger: "bg-red-500 ring-red-100",
};
---

<ol
  class:list={[
    orientation === "vertical" ? "relative border-l border-gray-200 space-y-8 ml-3" : "flex items-start gap-4",
    className,
  ]}
  aria-label="Timeline"
>
  {items.length > 0 ? items.map((item) => (
    <li class="relative pl-6">
      <!-- Dot -->
      <span
        class:list={[
          "absolute -left-[9px] top-1 flex h-4 w-4 items-center justify-center rounded-full ring-4",
          dotColorMap[item.variant ?? "default"],
        ]}
        aria-hidden="true"
      />
      <!-- Content -->
      <div>
        <p class="text-sm font-semibold text-gray-900">{item.title}</p>
        {item.description && (
          <p class="mt-0.5 text-sm text-gray-500">{item.description}</p>
        )}
        {item.date && (
          <time class="mt-1 block text-xs text-gray-400">{item.date}</time>
        )}
      </div>
    </li>
  )) : (
    <slot />
  )}
</ol>
