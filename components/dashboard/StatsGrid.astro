---
/**
 * StatsGrid - Responsive grid of key metric StatCards for dashboards.
 *
 * @component StatsGrid
 * @category dashboard
 * @slot default - StatCard components or custom metric cells
 */

export interface StatItem {
  /** Metric label */
  label: string;
  /** Displayed value */
  value: string | number;
  /** Change description (e.g., "+12% vs last month") */
  change?: string;
  /** Trend direction */
  trend?: "up" | "down" | "neutral";
  /** SVG icon path */
  icon?: string;
  /** Icon color */
  iconVariant?: "primary" | "success" | "warning" | "danger" | "info";
}

export interface Props {
  /** Stats to render (or pass children via slot) */
  stats?: StatItem[];
  /** Number of columns */
  cols?: 2 | 3 | 4 | 5;
  /** Additional CSS classes */
  class?: string;
}

const {
  stats = [],
  cols = 4,
  class: className = "",
} = Astro.props;

const colMap: Record<number, string> = {
  2: "grid-cols-1 sm:grid-cols-2",
  3: "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3",
  4: "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4",
  5: "grid-cols-1 sm:grid-cols-2 lg:grid-cols-5",
};

const trendColor: Record<string, string> = {
  up: "text-green-600",
  down: "text-red-600",
  neutral: "text-gray-500",
};

const iconBgMap: Record<string, string> = {
  primary: "bg-blue-100 text-blue-600",
  success: "bg-green-100 text-green-600",
  warning: "bg-yellow-100 text-yellow-600",
  danger: "bg-red-100 text-red-600",
  info: "bg-sky-100 text-sky-600",
};
---

<dl class:list={["grid gap-4", colMap[cols], className]}>
  {stats.length > 0
    ? stats.map((stat) => (
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 flex items-start gap-4">
        {stat.icon && (
          <div class:list={["flex-shrink-0 rounded-lg p-2.5", iconBgMap[stat.iconVariant ?? "primary"]]}>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={stat.icon} />
            </svg>
          </div>
        )}
        <div class="min-w-0 flex-1">
          <dt class="text-sm text-gray-500 font-medium truncate">{stat.label}</dt>
          <dd class="mt-1 text-2xl font-bold text-gray-900 tabular-nums">{stat.value}</dd>
          {stat.change && (
            <p class:list={["mt-1 text-xs font-medium", trendColor[stat.trend ?? "neutral"]]}>
              {stat.change}
            </p>
          )}
        </div>
      </div>
    ))
    : <slot />
  }
</dl>
