---
/**
 * Alert - Contextual notification banners for success, warning, error, and info.
 *
 * @component Alert
 * @category feedback
 * @accessibility role="alert" for errors, role="status" for informational
 * @slot default  - Alert body message
 * @slot title    - Optional bold heading
 * @slot actions  - Optional action buttons inside the alert
 */

export interface Props {
  /** Semantic type controls color and icon */
  variant?: "info" | "success" | "warning" | "error";
  /** Bold heading above the message */
  title?: string;
  /** Allow the user to dismiss the alert */
  dismissible?: boolean;
  /** Render with full-width left border accent */
  bordered?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const {
  variant = "info",
  title,
  dismissible = false,
  bordered = false,
  class: className = "",
} = Astro.props;

const variantMap: Record<string, { bg: string; text: string; border: string; icon: string }> = {
  info: {
    bg: "bg-blue-50",
    text: "text-blue-800",
    border: "border-blue-400",
    icon: "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  success: {
    bg: "bg-green-50",
    text: "text-green-800",
    border: "border-green-400",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  warning: {
    bg: "bg-yellow-50",
    text: "text-yellow-800",
    border: "border-yellow-400",
    icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
  },
  error: {
    bg: "bg-red-50",
    text: "text-red-800",
    border: "border-red-400",
    icon: "M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
};

const v = variantMap[variant];
---

<div
  role={variant === "error" ? "alert" : "status"}
  aria-live={variant === "error" ? "assertive" : "polite"}
  class:list={[
    "relative flex gap-3 rounded-md p-4",
    v.bg,
    v.text,
    bordered ? `border-l-4 ${v.border}` : "border border-transparent",
    className,
  ]}
>
  <!-- Icon -->
  <svg class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24"
    stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={v.icon} />
  </svg>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    {title && <p class="font-semibold text-sm mb-1">{title}</p>}
    <div class="text-sm">
      <slot />
    </div>
    <div class="mt-2 flex items-center gap-2">
      <slot name="actions" />
    </div>
  </div>

  <!-- Dismiss button -->
  {dismissible && (
    <button
      type="button"
      aria-label="Dismiss alert"
      class:list={["flex-shrink-0 rounded p-1 hover:bg-black/10 transition-colors focus:outline-none focus:ring-2 focus:ring-current", v.text]}
      onclick="this.closest('[role]').remove()"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  )}
</div>
