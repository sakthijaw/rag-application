---
/**
 * Toast - Brief auto-dismissing notification overlay.
 *
 * @component Toast
 * @category feedback
 * @accessibility aria-live="polite", role="status"
 */

export interface Props {
  /** Notification type */
  variant?: "info" | "success" | "warning" | "error";
  /** Toast message */
  message: string;
  /** Position on screen */
  position?: "top-right" | "top-left" | "bottom-right" | "bottom-left" | "top-center";
  /** Auto-dismiss duration in milliseconds (0 = persistent) */
  duration?: number;
  /** Show a close button */
  dismissible?: boolean;
}

const {
  variant = "info",
  message,
  position = "top-right",
  duration = 4000,
  dismissible = true,
} = Astro.props;

const variantMap: Record<string, { bg: string; icon: string; iconPath: string }> = {
  info: { bg: "bg-blue-600", icon: "text-white", iconPath: "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
  success: { bg: "bg-green-600", icon: "text-white", iconPath: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
  warning: { bg: "bg-yellow-500", icon: "text-white", iconPath: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" },
  error: { bg: "bg-red-600", icon: "text-white", iconPath: "M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" },
};

const posMap: Record<string, string> = {
  "top-right": "top-4 right-4",
  "top-left": "top-4 left-4",
  "bottom-right": "bottom-4 right-4",
  "bottom-left": "bottom-4 left-4",
  "top-center": "top-4 left-1/2 -translate-x-1/2",
};

const v = variantMap[variant];
---

<div
  id="toast"
  role="status"
  aria-live="polite"
  aria-atomic="true"
  class:list={[
    "fixed z-[100] flex items-center gap-3 min-w-[280px] max-w-sm px-4 py-3 rounded-lg shadow-lg text-white transition-all duration-300",
    v.bg,
    posMap[position],
  ]}
  data-duration={duration}
>
  <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24"
    stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={v.iconPath} />
  </svg>

  <p class="flex-1 text-sm font-medium">{message}</p>

  {dismissible && (
    <button
      type="button"
      aria-label="Close notification"
      onclick="document.getElementById('toast').remove()"
      class="ml-1 rounded p-0.5 hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white transition-colors"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  )}
</div>

{duration > 0 && (
  <script define:vars={{ duration }}>
    setTimeout(() => {
      const t = document.getElementById("toast");
      if (t) { t.style.opacity = "0"; setTimeout(() => t.remove(), 300); }
    }, duration);
  </script>
)}
