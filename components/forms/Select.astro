---
/**
 * Select - Styled native dropdown select with label and error support.
 *
 * @component Select
 * @category forms
 * @accessibility aria-invalid, aria-describedby, required attribute
 */

export interface SelectOption {
  value: string;
  label: string;
  disabled?: boolean;
}

export interface Props {
  /** Unique id for label association */
  id: string;
  /** Field label */
  label?: string;
  /** Available options */
  options: SelectOption[];
  /** Currently selected value */
  value?: string;
  /** Placeholder option text */
  placeholder?: string;
  /** Mark as required */
  required?: boolean;
  /** Disabled state */
  disabled?: boolean;
  /** Error message */
  error?: string;
  /** Helper text */
  helper?: string;
  /** Size preset */
  size?: "sm" | "md" | "lg";
  /** Additional CSS classes */
  class?: string;
}

const {
  id,
  label,
  options,
  value,
  placeholder = "Select an option",
  required = false,
  disabled = false,
  error,
  helper,
  size = "md",
  class: className = "",
} = Astro.props;

const sizeMap: Record<string, string> = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-3.5 py-2 text-sm",
  lg: "px-4 py-2.5 text-base",
};

const errorId = error ? `${id}-error` : undefined;
const helperId = helper ? `${id}-helper` : undefined;
const describedBy = [errorId, helperId].filter(Boolean).join(" ") || undefined;
---

<div class="flex flex-col gap-1">
  {label && (
    <label for={id} class:list={["block text-sm font-medium", error ? "text-red-600" : "text-gray-700"]}>
      {label}
      {required && <span class="text-red-500 ml-0.5" aria-hidden="true">*</span>}
    </label>
  )}

  <div class="relative">
    <select
      id={id}
      name={id}
      required={required}
      disabled={disabled}
      aria-invalid={error ? "true" : "false"}
      aria-describedby={describedBy}
      class:list={[
        "block w-full rounded-md border bg-white shadow-sm appearance-none pr-8 transition-colors",
        "focus:outline-none focus:ring-2 focus:ring-offset-0",
        error
          ? "border-red-400 focus:border-red-400 focus:ring-red-300"
          : "border-gray-300 focus:border-blue-500 focus:ring-blue-200",
        disabled ? "bg-gray-50 text-gray-400 cursor-not-allowed" : "text-gray-900 cursor-pointer",
        sizeMap[size],
        className,
      ]}
    >
      {placeholder && <option value="" disabled selected={!value}>{placeholder}</option>}
      {options.map((opt) => (
        <option value={opt.value} selected={opt.value === value} disabled={opt.disabled}>
          {opt.label}
        </option>
      ))}
    </select>
    <!-- Custom dropdown chevron -->
    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-500">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

  {helper && !error && <p id={helperId} class="text-xs text-gray-500">{helper}</p>}
  {error && <p id={errorId} role="alert" class="text-xs text-red-600">{error}</p>}
</div>
