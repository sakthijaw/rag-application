---
/**
 * Article - Long-form content layout with header, author meta, body prose, and table of contents support.
 *
 * @component Article
 * @category content
 * @slot cover      - Hero/cover image
 * @slot default    - Main article body content (markdown prose)
 * @slot sidebar    - Optional right-side TOC or related links
 * @slot tags       - Tag badge list
 * @slot author     - Author bio block
 */

export interface Props {
  /** Article title */
  title: string;
  /** Subtitle or deck */
  subtitle?: string;
  /** Author name */
  authorName?: string;
  /** Author role */
  authorRole?: string;
  /** Author avatar URL */
  authorImage?: string;
  /** Published date ISO string */
  publishedAt?: string;
  /** Updated date ISO string */
  updatedAt?: string;
  /** Estimated reading time */
  readTime?: string;
  /** Category */
  category?: string;
  /** Enable sidebar column layout */
  hasSidebar?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const {
  title,
  subtitle,
  authorName,
  authorRole,
  authorImage,
  publishedAt,
  updatedAt,
  readTime,
  category,
  hasSidebar = false,
  class: className = "",
} = Astro.props;

const initials = (authorName ?? "A").split(" ").map(n => n[0]).join("").slice(0, 2).toUpperCase();
---

<article
  class:list={["max-w-4xl mx-auto px-4 sm:px-6 py-10", className]}
  itemscope
  itemtype="https://schema.org/Article"
>
  <!-- Cover -->
  <slot name="cover" />

  <!-- Header -->
  <header class="mb-8">
    {category && (
      <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">{category}</span>
    )}
    <h1
      itemprop="headline"
      class="mt-2 text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight leading-tight"
    >
      {title}
    </h1>
    {subtitle && (
      <p class="mt-3 text-lg text-gray-600 leading-relaxed">{subtitle}</p>
    )}

    <!-- Author + meta row -->
    {(authorName || publishedAt) && (
      <div class="mt-6 flex items-center gap-3 flex-wrap">
        {authorImage ? (
          <img src={authorImage} alt={authorName ?? "Author"}
            class="h-10 w-10 rounded-full object-cover flex-shrink-0" />
        ) : authorName ? (
          <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-100 text-blue-700 font-semibold flex-shrink-0">
            {initials}
          </span>
        ) : null}

        <div itemprop="author" itemscope itemtype="https://schema.org/Person">
          {authorName && (
            <p class="text-sm font-semibold text-gray-900" itemprop="name">{authorName}</p>
          )}
          {authorRole && (
            <p class="text-xs text-gray-500" itemprop="jobTitle">{authorRole}</p>
          )}
        </div>

        <div class="flex items-center gap-2 text-xs text-gray-400 ml-auto">
          {publishedAt && (
            <time datetime={publishedAt} itemprop="datePublished">{publishedAt}</time>
          )}
          {readTime && <span>· {readTime} read</span>}
          {updatedAt && <span>· Updated {updatedAt}</span>}
        </div>
      </div>
    )}

    <!-- Tags -->
    <div class="mt-4 flex flex-wrap gap-2">
      <slot name="tags" />
    </div>
  </header>

  <!-- Body + optional sidebar -->
  <div class:list={[hasSidebar ? "grid grid-cols-1 lg:grid-cols-[1fr_240px] gap-10" : ""]}>
    <div
      itemprop="articleBody"
      class="prose prose-gray max-w-none prose-headings:font-bold prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline"
    >
      <slot />
    </div>
    {hasSidebar && (
      <aside class="hidden lg:block" aria-label="Article sidebar">
        <slot name="sidebar" />
      </aside>
    )}
  </div>

  <!-- Author bio footer -->
  <footer class="mt-12 pt-8 border-t border-gray-200">
    <slot name="author" />
  </footer>
</article>
