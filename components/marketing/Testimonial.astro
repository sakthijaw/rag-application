---
/**
 * Testimonial - Customer quote card with avatar, name, role, and star rating.
 *
 * @component Testimonial
 * @category marketing
 * @slot quote - Full testimonial quote text (overrides quote prop)
 */

export interface Props {
  /** Quote text */
  quote?: string;
  /** Customer full name */
  authorName: string;
  /** Job title / company */
  authorRole?: string;
  /** Avatar image URL */
  authorImage?: string;
  /** Star rating 1–5 */
  rating?: number;
  /** Card or minimal style */
  variant?: "card" | "minimal" | "featured";
  /** Additional CSS classes */
  class?: string;
}

const {
  quote,
  authorName,
  authorRole,
  authorImage,
  rating = 5,
  variant = "card",
  class: className = "",
} = Astro.props;

const initials = authorName.split(" ").map(n => n[0]).join("").slice(0, 2).toUpperCase();
---

<figure
  class:list={[
    variant === "card"
      ? "bg-white rounded-xl border border-gray-200 shadow-sm p-6 flex flex-col gap-4"
      : variant === "featured"
      ? "bg-blue-600 text-white rounded-2xl p-8 flex flex-col gap-6"
      : "flex flex-col gap-4",
    className,
  ]}
>
  <!-- Stars -->
  {rating > 0 && (
    <div class="flex items-center gap-0.5" aria-label={`Rating: ${rating} out of 5 stars`}>
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          class:list={["h-4 w-4", i < rating ? (variant === "featured" ? "text-yellow-300" : "text-yellow-400") : "text-gray-200"]}
          fill="currentColor"
          viewBox="0 0 20 20"
          aria-hidden="true"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
  )}

  <!-- Quote -->
  <blockquote>
    <p class:list={[
      "text-sm leading-relaxed",
      variant === "featured" ? "text-blue-50 text-base" : "text-gray-700",
    ]}>
      <slot name="quote">&ldquo;{quote}&rdquo;</slot>
    </p>
  </blockquote>

  <!-- Author -->
  <figcaption class="flex items-center gap-3 mt-auto">
    {authorImage ? (
      <img
        src={authorImage}
        alt={authorName}
        class="h-10 w-10 rounded-full object-cover flex-shrink-0"
      />
    ) : (
      <span class:list={[
        "inline-flex items-center justify-center h-10 w-10 rounded-full text-sm font-semibold flex-shrink-0",
        variant === "featured" ? "bg-blue-400 text-white" : "bg-blue-100 text-blue-700",
      ]}>
        {initials}
      </span>
    )}
    <div>
      <p class:list={["text-sm font-semibold", variant === "featured" ? "text-white" : "text-gray-900"]}>
        {authorName}
      </p>
      {authorRole && (
        <p class:list={["text-xs", variant === "featured" ? "text-blue-200" : "text-gray-500"]}>
          {authorRole}
        </p>
      )}
    </div>
  </figcaption>
</figure>
