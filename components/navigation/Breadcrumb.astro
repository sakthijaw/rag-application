---
/**
 * Breadcrumb - Hierarchical page location trail.
 *
 * @component Breadcrumb
 * @category navigation
 * @accessibility aria-label="Breadcrumb", aria-current="page" on last item
 */

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  /** Ordered list of breadcrumb items; last item is current page */
  items: BreadcrumbItem[];
  /** Separator character or symbol */
  separator?: string;
  /** Additional CSS classes */
  class?: string;
}

const {
  items,
  separator = "/",
  class: className = "",
} = Astro.props;
---

<nav aria-label="Breadcrumb" class:list={[className]}>
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500">
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      return (
        <li class="flex items-center gap-1.5">
          {index > 0 && (
            <span class="text-gray-300 select-none" aria-hidden="true">{separator}</span>
          )}
          {isLast ? (
            <span
              aria-current="page"
              class="font-medium text-gray-900 truncate max-w-[200px]"
            >
              {item.label}
            </span>
          ) : (
            <a
              href={item.href ?? "#"}
              class="hover:text-blue-600 hover:underline underline-offset-2 transition-colors truncate max-w-[160px]"
            >
              {item.label}
            </a>
          )}
        </li>
      );
    })}
  </ol>
</nav>
