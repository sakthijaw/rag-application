---
/**
 * Tabs - Horizontal tab navigation for switching between content panels.
 *
 * @component Tabs
 * @category navigation
 * @accessibility role="tablist", role="tab", role="tabpanel", aria-selected, aria-controls
 */

export interface Tab {
  /** Unique tab id */
  id: string;
  /** Tab label */
  label: string;
  /** Optional badge count */
  count?: number;
  /** Disabled tab */
  disabled?: boolean;
}

export interface Props {
  /** Tab definitions */
  tabs: Tab[];
  /** Currently active tab id */
  activeTab?: string;
  /** Visual style variant */
  variant?: "line" | "pills" | "boxed";
  /** Additional CSS classes */
  class?: string;
}

const {
  tabs,
  activeTab,
  variant = "line",
  class: className = "",
} = Astro.props;

const active = activeTab ?? tabs[0]?.id;

const variantWrapper: Record<string, string> = {
  line: "border-b border-gray-200",
  pills: "bg-gray-100 rounded-lg p-1 gap-1",
  boxed: "border border-gray-200 rounded-lg p-1 gap-1 bg-gray-50",
};

const tabBase = "inline-flex items-center gap-2 text-sm font-medium transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1 disabled:opacity-40 disabled:cursor-not-allowed";

const tabVariant: Record<string, { active: string; inactive: string }> = {
  line: {
    active: "border-b-2 border-blue-600 text-blue-600 pb-3 px-4",
    inactive: "text-gray-500 hover:text-gray-700 pb-3 px-4 border-b-2 border-transparent hover:border-gray-300",
  },
  pills: {
    active: "bg-white text-blue-700 shadow-sm rounded-md px-3 py-1.5",
    inactive: "text-gray-500 hover:text-gray-700 rounded-md px-3 py-1.5",
  },
  boxed: {
    active: "bg-white text-gray-900 shadow-sm rounded px-3 py-1.5",
    inactive: "text-gray-500 hover:text-gray-700 rounded px-3 py-1.5",
  },
};
---

<div class:list={[className]}>
  <!-- Tab list -->
  <div
    role="tablist"
    aria-label="Content tabs"
    class:list={["flex items-center", variantWrapper[variant]]}
  >
    {tabs.map((tab) => {
      const isActive = tab.id === active;
      return (
        <button
          role="tab"
          id={`tab-${tab.id}`}
          aria-selected={isActive ? "true" : "false"}
          aria-controls={`panel-${tab.id}`}
          tabindex={isActive ? 0 : -1}
          disabled={tab.disabled}
          class:list={[
            tabBase,
            isActive ? tabVariant[variant].active : tabVariant[variant].inactive,
          ]}
          data-tab={tab.id}
        >
          {tab.label}
          {tab.count !== undefined && (
            <span class:list={[
              "rounded-full text-xs px-1.5 py-0.5 font-mono",
              isActive ? "bg-blue-100 text-blue-700" : "bg-gray-100 text-gray-600",
            ]}>
              {tab.count}
            </span>
          )}
        </button>
      );
    })}
  </div>

  <!-- Tab panels slot -->
  <div class="mt-4">
    <slot />
  </div>
</div>

<script>
  const tabs = document.querySelectorAll("[role='tab']");
  const panels = document.querySelectorAll("[role='tabpanel']");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = tab.getAttribute("data-tab");
      tabs.forEach((t) => t.setAttribute("aria-selected", "false"));
      tab.setAttribute("aria-selected", "true");
      panels.forEach((p) => p.setAttribute("hidden", ""));
      document.getElementById(`panel-${target}`)?.removeAttribute("hidden");
    });
  });
</script>
