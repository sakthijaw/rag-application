---
/**
 * Grid - Responsive CSS Grid layout system.
 *
 * @component Grid
 * @category layout
 * @slot default - Grid child items
 */

export interface Props {
  /** Number of columns on desktop (1–12) */
  cols?: 1 | 2 | 3 | 4 | 6 | 12;
  /** Column count on tablet */
  colsMd?: 1 | 2 | 3 | 4 | 6 | 12;
  /** Column count on mobile */
  colsSm?: 1 | 2 | 3;
  /** Gap between items: none | sm | md | lg | xl */
  gap?: "none" | "sm" | "md" | "lg" | "xl";
  /** Additional CSS classes */
  class?: string;
}

const {
  cols = 3,
  colsMd = 2,
  colsSm = 1,
  gap = "md",
  class: className = "",
} = Astro.props;

const colMap: Record<number, string> = {
  1: "lg:grid-cols-1",
  2: "lg:grid-cols-2",
  3: "lg:grid-cols-3",
  4: "lg:grid-cols-4",
  6: "lg:grid-cols-6",
  12: "lg:grid-cols-12",
};

const colMdMap: Record<number, string> = {
  1: "md:grid-cols-1",
  2: "md:grid-cols-2",
  3: "md:grid-cols-3",
  4: "md:grid-cols-4",
  6: "md:grid-cols-6",
  12: "md:grid-cols-12",
};

const colSmMap: Record<number, string> = {
  1: "grid-cols-1",
  2: "grid-cols-2",
  3: "grid-cols-3",
};

const gapMap = {
  none: "gap-0",
  sm: "gap-3",
  md: "gap-6",
  lg: "gap-8",
  xl: "gap-12",
};
---

<div
  class:list={[
    "grid",
    colSmMap[colsSm],
    colMdMap[colsMd],
    colMap[cols],
    gapMap[gap],
    className,
  ]}
>
  <slot />
</div>
